{
    "name": "@darraghor/nest-backend-libs",
    "version": "1.0.1",
    "license": "SEE LICENSE IN LICENSE.md",
    "description": "Some helpers for personal projects in nestjs",
    "homepage": "https://github.com/darraghoriordan/nest-backend-libs",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "https://github.com/darraghoriordan/nest-backend-libs"
    },
    "engines": {
        "node": ">=22.21.1"
    },
    "files": [
        "dist",
        "package.json",
        "README.md"
    ],
    "author": {
        "name": "Darragh ORiordan",
        "email": "darragh.oriordan@gmail.com",
        "url": "https://darraghoriordan.com"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "keywords": [
        "nestjs"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "pnpm": {
        "overrides": {
            "conventional-changelog-conventionalcommits": "7.0.2"
        }
    },
    "bin": {
        "miller": "dist/cli/cli.js",
        "generate-client": "dist/open-api-generation/generate.sh"
    },
    "scripts": {
        "clean": "rm -Rf ./dist/",
        "build:ci": "pnpm run build",
        "build": "pnpm run clean && mkdir ./dist && tsc --project tsconfig.build.json && pnpm run copyOpenApiGenerationModule",
        "lint": "pnpm exec eslint",
        "lintone": "pnpm exec eslint  --no-error-on-unmatched-pattern",
        "test": "vitest run",
        "pre-commit": "npx lint-staged",
        "prettier": "prettier --write src/*",
        "prepare": "husky",
        "knip": "knip",
        "release": "npx semantic-release",
        "semantic-release": "semantic-release",
        "copyOpenApiGenerationModule": "copyfiles --error --up 1 \"src/open-api-generation/**/*\" \"src/open-api-generation/*\" \"src/database-initialisation/*\" dist"
    },
    "peerDependencies": {
        "@nestjs/axios": "^4.0.0",
        "@nestjs/bullmq": "^11.0.0",
        "@nestjs/common": "^11.0.0",
        "@nestjs/config": "^4.0.0",
        "@nestjs/core": "^11.0.0",
        "@nestjs/microservices": "^11.0.0",
        "@nestjs/passport": "^11.0.0",
        "@nestjs/platform-express": "^11.0.0",
        "@nestjs/swagger": "^11.0.0",
        "@nestjs/terminus": "^11.0.0",
        "@nestjs/typeorm": "^11.0.0",
        "bullmq": "^5.0.0",
        "class-transformer": "^0.5.0",
        "class-validator": "^0.14.0",
        "reflect-metadata": "^0.2.0",
        "typeorm": "^0.3.0"
    },
    "dependencies": {
        "@keyv/redis": "5.1.6",
        "@nestjs/axios": "4.0.1",
        "@nestjs/bullmq": "11.0.4",
        "@nestjs/cache-manager": "3.1.3",
        "@nestjs/common": "11.1.28",
        "@nestjs/config": "4.0.4",
        "@nestjs/core": "11.1.28",
        "@nestjs/microservices": "11.1.28",
        "@nestjs/passport": "11.0.5",
        "@nestjs/platform-express": "11.1.28",
        "@nestjs/swagger": "11.4.6",
        "@nestjs/terminus": "11.1.1",
        "@nestjs/typeorm": "11.0.3",
        "add": "2.0.6",
        "auth0": "6.0.0",
        "axios": "1.18.1",
        "bullmq": "5.80.8",
        "cache-manager": "7.2.9",
        "chalk": "5.6.2",
        "class-transformer": "0.5.1",
        "class-validator": "0.15.1",
        "date-fns": "4.4.0",
        "dotenv": "17.4.2",
        "helmet": "8.3.0",
        "jwks-rsa": "4.1.0",
        "nanoid": "6.0.0",
        "nestjs-pino": "4.6.1",
        "nodemailer": "9.0.3",
        "passport": "0.7.0",
        "passport-headerapikey": "1.2.2",
        "passport-jwt": "4.0.1",
        "pino-http": "11.0.0",
        "pino-pretty": "13.1.3",
        "redis": "6.1.0",
        "reflect-metadata": "0.2.2",
        "rimraf": "6.1.3",
        "rxjs": "7.8.2",
        "stripe": "22.3.2",
        "swagger-ui-express": "5.0.1",
        "twitter-api-v2": "1.29.0",
        "typeorm": "0.3.27"
    },
    "devDependencies": {
        "@commitlint/cli": "21.2.1",
        "@commitlint/config-conventional": "21.2.0",
        "@darraghor/eslint-plugin-nestjs-typed": "7.2.5",
        "@eslint/js": "10.0.1",
        "@nestjs/cli": "11.0.24",
        "@nestjs/schematics": "^11.1.0",
        "@nestjs/testing": "11.1.28",
        "@semantic-release/changelog": "6.0.3",
        "@semantic-release/exec": "7.1.0",
        "@types/auth0": "3.3.11",
        "@types/express": "5.0.6",
        "@types/node": "26.1.1",
        "@types/nodemailer": "8.0.1",
        "@types/passport-jwt": "4.0.1",
        "@types/supertest": "7.2.1",
        "@types/yargs": "17.0.35",
        "@typescript-eslint/eslint-plugin": "8.65.0",
        "@typescript-eslint/parser": "8.65.0",
        "copyfiles": "2.4.1",
        "eslint": "10.7.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-sonarjs": "4.2.0",
        "eslint-plugin-unicorn": "72.0.0",
        "globals": "17.7.0",
        "husky": "9.1.7",
        "knip": "6.27.0",
        "lint-staged": "17.1.0",
        "prettier": "3.9.5",
        "semantic-release": "25.0.8",
        "ts-loader": "9.6.2",
        "ts-node": "10.9.2",
        "tsconfig-paths": "4.2.0",
        "typescript": "5.9.3",
        "typescript-eslint": "8.65.0",
        "vitest": "4.1.10",
        "yargs": "18.0.0"
    },
    "lint-staged": {
        "*.ts": "eslint --cache --fix",
        "*.{ts,js,css,md}": "prettier --write"
    },
    "release": {
        "branches": [
            "main"
        ]
    }
}
